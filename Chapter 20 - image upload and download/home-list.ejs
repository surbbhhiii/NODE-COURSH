<%- include('../partials/head') %>
<body>
  <%- include('../partials/nav') %>
  
  <main style="max-width: 1200px; margin: 40px auto; padding: 0 20px; font-family: sans-serif;">
    <h1 style="text-align: center; color: red; margin-bottom: 40px; font-weight: 600; font-size: 2.5rem;">
     Here are our registered homes:
    </h1>

    <div style="display: flex; flex-wrap: wrap; gap: 30px; justify-content: center;">
      <% if (registeredHomes && registeredHomes.length > 0) { %>
        <% registeredHomes.forEach(home => { %>

          <div style="width: 300px; background: white; border-radius: 15px; overflow: hidden; box-shadow: 0 8px 20px rgba(0,0,0,0.1); border: 1px solid #eee; margin-bottom: 20px;">
            
            <div style="width: 100%; height: 200px;">
              <img src="<%= home.photoUrl %>" style="width: 100%; height: 100%; object-fit: cover;" onerror="this.src='https://via.placeholder.com/300x200?text=No+Image'">
            </div>

            <div style="padding: 15px;">
              <h3 style="margin: 0; font-weight: 800; color: #333;"><%= home.houseName %></h3>
              <p style="margin: 5px 0; color: red; font-weight: 800;">📍 <%= home.location %></p>
              
              <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 12px;">
                <div style="font-weight: bold; color: #ff385c; font-size: 1rem;">
                  Rs <%= home.price %> <span style="font-weight: bold; font-size: 1.15rem; color: red;">/ Night</span>
                </div>
                
                <div style="font-size: 15px; font-weight: 700; display: flex; align-items: center; gap: 4px;">
                  <span style="color: #ffcc00; font-size: 15px;">★</span> 
                  <span style="color: #333;"><%= home.rating || '4.2' %></span>
                </div>
              </div>

              <div style="margin-top: 20px; display: flex; gap: 10px;">
                <a href="/homes/<%= home._id.toString() %>" 
                   style="flex: 1; text-align: center; text-decoration: none; padding: 10px; background: #94c4ec; color: #010c0e; border-radius: 8px; font-weight: 600; font-size: 13px; transition: 0.2s;">
                   Details
                </a>

                <form action="/favourites" method="POST" style="flex: 1; margin: 0;">
                  <input type="hidden" name="id" value="<%= home._id.toString() %>">
                  <button type="submit" style="width: 100%; padding: 10px; background: #90ee90; color: #222; border: none; border-radius: 8px; font-weight: 600; font-size: 13px; cursor: pointer;">
                    Favourite
                  </button>
                </form>
              </div>
            </div>
          </div>

        <% }) %>
      <% } else { %>
        <div style="text-align: center; width: 100%;">
          <p style="font-size: 1.2rem; color: #666;">No homes found in the list!</p>
        </div>
      <% } %>
    </div>
  </main>
</body>