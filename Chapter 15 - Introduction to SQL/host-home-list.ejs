<%- include('../partials/head') %>
<body>
  <%- include('../partials/nav') %>
  <main style="max-width: 1100px; margin: 40px auto; padding: 0 20px; font-family: sans-serif;">
    <h2 style="text-align: center; color: #d9534f; font-size: 2.2rem; font-weight: bold; margin-bottom: 35px;">Hey Host, here are your Homes:</h2>
    
    <!-- flex-wrap add kiya hai taaki multiple cards niche wali line mein aa sakein -->
    <div style="display: flex; justify-content: center; flex-wrap: wrap; gap: 20px;">
      <% if (typeof registeredHomes !== 'undefined' && registeredHomes.length > 0) { %>
        <% registeredHomes.forEach(home => { %> 
          <div style="width: 350px; background: white; border-radius: 15px; overflow: hidden; box-shadow: 0 8px 20px rgba(0,0,0,0.1); border: 1px solid #eee;">
            <img src="<%= home.photoUrl %>" style="width: 100%; height: 220px; object-fit: cover;">
            
            <div style="padding: 20px; text-align: left;">
              <h3 style="margin: 0; font-size: 1.3rem; color: #333; font-weight: 800;"><%= home.houseName %></h3>
              <p style="margin: 8px 0; color: #f42d2d; font-size: 16px; font-weight: bolder;">📍 <%= home.location %></p>
              
              <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 10px;">
                <div style="color: #ff385c; font-weight: bold; font-size: 1.2rem;">₹<%= home.price %> <span style="font-size: 14px; color: #ef4444; font-weight: bolder;">/ Night</span></div>
                <div style="font-weight: bold; font-size: 15px;"><span style="color: #ffce3d;">★</span> <%= home.rating %></div>
              </div>

              
              <div style="display: flex; justify-content: space-between; gap: 10px; margin-top: 20px;">
              

                <a href="/host/edit-home/<%= home.id %>?editing=true" style="flex: 1; text-align: center; background: #3b82f6; color: white; text-decoration: none; padding: 10px; border-radius: 8px; font-weight: bold; font-size: 14px;">Edit</a>
                
              

                <form action="/host/delete-home/<%= home.id %>" method="POST" style="flex: 1;">
                 <input type="hidden" name="homeId" value="<%= home.id %>">
                    <button type="submit" style="width: 100%; background: #ef4444; color: white; border: none; padding: 10px; border-radius: 8px; font-weight: bold; font-size: 14px; cursor: pointer;">Delete</button>
                  </form>
              </div>
              

            </div>
          </div>
        <% }) %>
      <% } else { %>
        <p>No homes found. Add some!</p>
      <% } %>
    </div>
  </main>
</body>
