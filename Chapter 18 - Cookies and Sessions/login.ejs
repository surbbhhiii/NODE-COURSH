<%- include('../partials/head') %>
</head>
<body class="bg-gray-100">
  <%- include('../partials/nav') %>
  <main class="container mx-auto mt-12 p-8 bg-white rounded-lg shadow-md max-w-md">
    <h1 class="text-3xl font-bold mb-6 text-center text-gray-800">Login with your info</h1>
    
    <form action="/login" method="POST">
      <div class="mb-4">
        <input type="email" name="email" placeholder="Email/Username" 
               class="w-full px-4 py-3 border border-gray-300 rounded focus:ring-1 focus:ring-red-500 outline-none" required>
      </div>

      <div class="mb-6">
        <input type="password" name="password" placeholder="Enter Your Password" 
               class="w-full px-4 py-3 border border-gray-300 rounded focus:ring-1 focus:ring-red-500 outline-none" required>
      </div>

      <button type="submit" class="w-full bg-red-500 text-white py-3 rounded font-semibold hover:bg-red-600 transition">
        Sign In
      </button>
    </form>
  </main>
</body>
</html>