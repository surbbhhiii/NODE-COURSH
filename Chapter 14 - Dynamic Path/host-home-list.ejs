<%- include('../partials/head') %>
<body>
  <%- include('../partials/nav') %>
  <main style="max-width: 1100px; margin: 40px auto; padding: 0 20px; font-family: sans-serif;">
    <h2 style="text-align: center; color: #d9534f; font-size: 2.2rem; font-weight: bold; margin-bottom: 35px;">Welcome to airbnb</h2>
    <div style="display: flex; justify-content: center;">
      <% if (typeof registeredHomes !== 'undefined' && registeredHomes.length > 0) { %>
        <% registeredHomes.slice(0, 1).forEach(home => { %> 
          <div style="width: 350px; background: white; border-radius: 15px; overflow: hidden; box-shadow: 0 8px 20px rgba(0,0,0,0.1); border: 1px solid #eee;">
            <img src="<%= home.photoUrl %>" style="width: 100%; height: 220px; object-fit: cover;">
            <div style="padding: 20px; text-align: left;">
              <h3 style="margin: 0; font-size: 1.4rem; color: #333; font-weight: bold;"><%= home.houseName %></h3>
              <p style="margin: 8px 0; color: #f42d2d; font-size: 16px; font-weight: bolder;">📍 <%= home.location %></p>
              <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 10px;">
                <div style="color: #ff385c; font-weight: bold; font-size: 1.3rem;">₹<%= home.price %> <span style="font-size: 14px; color: #777; font-weight: normal;">/ night</span></div>
                <div style="font-weight: bold; font-size: 15px;"><span style="color: #ffce3d;">★</span> <%= home.rating %></div>
              </div>
              <button style="width: 100%; background: #ff385c; color: white; border: none; padding: 12px; border-radius: 8px; font-weight: bold; margin-top: 20px; cursor: pointer;">Book</button>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </main>
</body>