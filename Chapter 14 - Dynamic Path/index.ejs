<%- include('../partials/head') %>
<body>
  <%- include('../partials/nav') %>

  <main style="max-width: 1200px; margin: 40px auto; padding: 0 20px; font-family: sans-serif;">
    <h2 style="text-align: center; color: #ff385c; margin-bottom: 40px; font-size: 2.2rem; font-weight: 600;">
      Welcome to airbnb index page:
    </h2>

    <div style="display: flex; flex-wrap: wrap; gap: 25px; justify-content: center;">
      <% if (registeredHomes.length > 0) { %>
        <% registeredHomes.forEach(home => { %> 
          
          <div style="width: 300px; position: relative; margin-bottom: 20px;">
            
            <form action="/favourites" method="POST" style="position: absolute; top: 15px; right: 15px; z-index: 10;">
              <input type="hidden" name="id" value="<%= home.id %>">
              <button type="submit" style="background: rgba(255,255,255,0.9); border: none; border-radius: 50%; width: 35px; height: 35px; cursor: pointer; color: #ff385c; font-size: 20px; display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 5px rgba(0,0,0,0.2);">
                ❤
              </button>
            </form>

            <div style="width: 100%; height: 280px; border-radius: 15px; overflow: hidden; background: #f3f3f3; margin-bottom: 12px;">
              <img src="<%= home.photoUrl %>" style="width: 100%; height: 100%; object-fit: cover;" onerror="this.src='https://via.placeholder.com/400x400?text=House'">
            </div>

            <div style="display: flex; flex-direction: column; gap: 2px;">
              <div style="display: flex; justify-content: space-between; align-items: baseline;">
                <h3 style="margin: 0; font-size: 16px; font-weight: 600; color: #222;"><%= home.houseName %></h3>
                <span style=" color: yellow; font-size: 14px;">★ <%= home.rating || '5' %></span>
              </div>
             <div>
              
              <p style="margin: 0; color: #dc1c1c; font-size: 15px; font-weight:bold;"><%= home.location %></p>
              </div>


              
              <div style="margin-top: 5px;">
                <span style="font-weight: 600; font-size: 16px; color: #ff385c;">Rs <%= home.price %></span>
                <span style="color: #ff385c;"> Night</span>
              </div>
            </div>

            <div style="margin-top: 15px; display: flex; gap: 10px;">
              <button style="flex: 2; padding: 10px; background: #ff385c; color: white; border: none; border-radius: 8px; font-weight: bold; cursor: pointer;">Book Now</button>
              
              <form action="/host/delete-home" method="POST" style="flex: 1;">
                 <input type="hidden" name="homeId" value="<%= home.id %>">
                 <button type="submit" style="width: 100%; padding: 10px; background: rgb(88, 178, 231); border: 1px solid #ddd; border-radius: 8px; cursor: pointer; font-weight: 600;">Delete</button>
              </form>
            </div>

          </div> 
        <% }) %>
      <% } else { %>
        <p style="text-align: center; width: 100%; font-size: 1.2rem; color: #717171;">No homes found.</p>
      <% } %>
    </div>
  </main>
</body>