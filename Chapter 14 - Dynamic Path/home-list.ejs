<%- include('../partials/head') %>
<body>
  <%- include('../partials/nav') %>
  <main
    style="
      max-width: 1200px;
      margin: 40px auto;
      padding: 0 20px;
      font-family: sans-serif;
    "
  >
    <h1
      style="
        text-align: center;
        color: #ff385c;
        margin-bottom: 40px;
        font-weight: 600;
        font-size: 2.5rem;
      "
    >
      You are in home detail page:
    </h1>

    <div style="display: flex; flex-wrap: wrap; gap: 30px; justify-content: center;">
        <% if (registeredHomes && registeredHomes.length > 
        0) { %>
        <% registeredHomes.forEach(home => { %>

          
          <div style="width: 320px; border: 1px solid #ddd; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 10px rgba(0,0,0,0.05); background: #fff;">
            
            <div style="width: 100%; height: 210px;">
              <img src="<%= home.photoUrl %>" style="width: 100%; height: 100%; object-fit: cover;">
            </div>

            <div style="padding: 16px;">
              <h3 style="margin: 0; font-size: 1.1rem; font-weight: 800; color: #222;"><%= home.houseName %></h3>
              
              <p style="margin: 4px 0; color: #010101; font-size: 14px; font-weight: 600;"><%= home.location %></p>
              
              <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 10px;">
                <div style="font-size: 16px;">
                   <span style="font-weight: 800; color: #ff385c;">Rs<%= home.price %> / Night</span>
                </div>
                <div style="font-weight: 700;color: #f9f233;">
                   ★ <%= home.rating || '4' %>
                </div>
                
              </div>

              <div style="margin-top: 15px; display: flex; gap: 10px;">

                <!--<a class="bg-blue-300 p-2" href="/homes/<%= home.id %>">Dtails</a>-->




                <a href="/homes/<%= home.id %>" 
   style="
     text-decoration: none; 
     padding: 6px 15px; 
     background: #94c4ec; /* Light Grey color */
     color: #010c0e; 
     border: 1px solid #ccc; 
     border-radius: 4px; 
     font-weight: 600; 
     cursor: pointer; 
     font-size: 13px;
     display: inline-block;
   ">
   Details
</a>


               

                <button style="padding: 6px 15px; background: #90ee90; color: #222; border: none; border-radius: 4px; font-weight: 600; cursor: pointer; font-size: 13px;">
                  Book
                </button>

                <form action="/host/delete-home" method="POST" style="margin: 0;">
                   <input type="hidden" name="homeId" value="<%= home.id %>">


                   <!--<button type="submit" style="padding: 6px 15px; background: rgb(116, 149, 226); border: 1px solid #ddd; border-radius: 4px; font-size: 13px; cursor: pointer;">
                     Delete
                   </button>-->
            </form>
              </div>
            </div>
          </div>

        <% }) %>
      <% } else { %>
        <p style="text-align: center; font-weight: 700; font-size: 1.5rem; color: #717171;">No homes found!</p>
      <% } %>
    </div>
  </main>
</body>
