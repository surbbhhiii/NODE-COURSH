<%- include('../partials/head') %>
<body>
  <%- include('../partials/nav') %>
  <main style="max-width: 1200px; margin: 40px auto; padding: 0 20px;">
    
    <h2 style="text-align: center; color: #ff385c; margin-bottom: 40px; font-size: 2.2rem; font-weight: 700;">Here are your favourite:</h2>

    <div style="display: flex; flex-wrap: wrap; gap: 30px; justify-content: center;">
      <% if (favouriteList && favouriteList.length > 0) { %>
        <% favouriteList.forEach(home => { %> 
          <div style="width: 300px; margin-bottom: 20px;">
            <div style="width: 100%; height: 280px; border-radius: 15px; overflow: hidden; margin-bottom: 12px;">
              <img src="<%= home.photoUrl %>" style="width: 100%; height: 100%; object-fit: cover;">
            </div>
            <div style="display: flex; justify-content: space-between; font-weight: 600;">
              <span><%= home.houseName %></span>
              <span>★ 5.0</span>
            </div>
            <p style="margin: 3px 0; color: #717171;"><%= home.location %></p>
            <p style="margin: 0;"><span style="font-weight: 600;">₹<%= home.price %></span> night</p>

            <div style="margin-top: 15px; display: flex; gap: 10px;">
              <button style="flex: 2; padding: 10px; background: #ff385c; color: white; border: none; border-radius: 8px; font-weight: bold; cursor: pointer;">Book Now</button>
              
              <form action="/favourites/delete" method="POST" style="flex: 1;">
                 <input type="hidden" name="id" value="<%= home.id %>">
                 <button type="submit" style="width: 100%; padding: 10px; background: white; border: 1px solid #ddd; border-radius: 8px; font-weight: 600;">Delete</button>
              </form>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <p style="text-align: center; font-size: 1.2rem; color: #717171;"></p>
      <% } %>
    </div>
  </main>
</body>